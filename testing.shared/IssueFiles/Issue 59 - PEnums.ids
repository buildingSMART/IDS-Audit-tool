<?xml version="1.0" encoding="utf-8"?>
<ids:ids xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://standards.buildingsmart.org/IDS http://standards.buildingsmart.org/IDS/1.0/ids.xsd" xmlns:ids="http://standards.buildingsmart.org/IDS">
	<ids:info>
		<ids:title />
	</ids:info>
	<ids:specifications>
		<ids:specification ifcVersion="IFC4X3_ADD2" name="Issue59" identifier="e027a9f1-03bb-4c8c-a94d-2102401dadfe">
			<ids:applicability minOccurs="0" maxOccurs="unbounded">
				<ids:entity>
					<ids:name>
						<xs:restriction base="xs:string">
							<xs:enumeration value="IFCCOMMUNICATIONSAPPLIANCE" />
						</xs:restriction>
					</ids:name>
					<ids:predefinedType>
						<ids:simpleValue>ANTENNA</ids:simpleValue>
					</ids:predefinedType>
				</ids:entity>
			</ids:applicability>
			<ids:requirements>
        
				<ids:property cardinality="required" dataType="IFCLABEL">
					<ids:propertySet>
						<ids:simpleValue>Pset_CommunicationsApplianceTypeAntenna</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>AntennaType</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<ids:simpleValue>PANEL</ids:simpleValue><!-- this is valid, because included in the enum -->
					</ids:value>
				</ids:property>
        
        <ids:property cardinality="required" dataType="IFCLABEL">
          <ids:propertySet>
            <ids:simpleValue>Pset_CommunicationsApplianceTypeAntenna</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>AntennaType</ids:simpleValue>
          </ids:baseName>
          <ids:value>
            <ids:simpleValue>NONVALIDENUM</ids:simpleValue><!-- this is Invalid, because limited by AntennaType -->
          </ids:value>
        </ids:property>

        <ids:property cardinality="required" dataType="IFCLABEL">
          <ids:propertySet>
            <ids:simpleValue>Pset_EnvironmentalImpactIndicators</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <xs:restriction base="xs:string">
              <xs:enumeration value="LifeCyclePhase" /><!--	IfcPropertyEnumeratedValue -->
              <xs:enumeration value="FunctionalUnitReference" />  <!-- IfcLabel -->
            </xs:restriction>
          </ids:baseName>
          <ids:value>
            <ids:simpleValue>NONVALIDENUM</ids:simpleValue><!-- this is valid because allowed by the freedom of FunctionalUnitReference -->
          </ids:value>
        </ids:property>

      </ids:requirements>
		</ids:specification>
	</ids:specifications>
</ids:ids>
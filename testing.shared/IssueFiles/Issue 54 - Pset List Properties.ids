<?xml version="1.0" encoding="utf-8"?>
<ids:ids xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://standards.buildingsmart.org/IDS http://standards.buildingsmart.org/IDS/1.0/ids.xsd" xmlns:ids="http://standards.buildingsmart.org/IDS">
	<ids:info>
		<ids:title />
	</ids:info>
	<ids:specifications>
		<ids:specification ifcVersion="IFC4X3_ADD2" name="Specification #1" identifier="cd3e9bcc-bf9e-431e-bfac-00db9ef72fb0">
			<ids:applicability minOccurs="0" maxOccurs="unbounded">
				<ids:entity>
					<ids:name>
						<xs:restriction base="xs:string">
							<xs:enumeration value="IFCACTOR" />
							<xs:enumeration value="IFCOCCUPANT" />
						</xs:restriction>
					</ids:name>
				</ids:entity>
			</ids:applicability>
			<ids:requirements>
				<ids:property cardinality="required">
					<ids:propertySet>
						<ids:simpleValue>Pset_Address</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>AddressLines</ids:simpleValue>
					</ids:baseName>
				</ids:property>
				<ids:property cardinality="required" dataType="IFCLABEL">
					<ids:propertySet>
						<ids:simpleValue>Pset_Address</ids:simpleValue>
					</ids:propertySet>
					<ids:baseName>
						<ids:simpleValue>TelephoneNumbers</ids:simpleValue>
					</ids:baseName>
					<ids:value>
						<xs:restriction base="xs:string">
							<xs:pattern value="\+\d+-\d+" />
						</xs:restriction>
					</ids:value>
				</ids:property>
        <ids:property cardinality="required">
          <ids:propertySet>
            <ids:simpleValue>Pset_Address</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>DoesNotExist</ids:simpleValue>
          </ids:baseName>
        </ids:property>
			</ids:requirements>
		</ids:specification>
	</ids:specifications>
</ids:ids>
	<ids:specifications>
		<ids:specification ifcVersion="IFC4X3_ADD2" name="Absorbed radioactivity dose model" description="Required for the Landscape Architect prerequisites" instructions="The property will be contain the information of the J / kg for the related entity.&#xD;&#xA;Its unit in the IDS exchange file is interpreted in J / kg(gray/ gray)&#xD;&#xA;IFC models will have the property stored as IfcUnitEnum.ABSORBEDDOSEUNIT&#xD;&#xA;" identifier="ced0da90-7fa4-4cee-9ebc-6061f4865732">
